    body { font-family: Calibri, Arial, sans-serif; font-size: 11pt; line-height: 1.4; color: #333; }
    h1 { font-size: 24pt; color: #1a1a1a; margin-bottom: 4pt; border-bottom: 2pt solid #1a1a1a; padding-bottom: 8pt; }
    h2 { font-size: 13pt; color: #1a1a1a; margin-top: 16pt; margin-bottom: 8pt; border-bottom: 1pt solid #ccc; padding-bottom: 4pt; text-transform: uppercase; letter-spacing: 1pt; }
    h3 { font-size: 11pt; color: #1a1a1a; margin-bottom: 2pt; }
    .subtitle { font-size: 12pt; color: #555; margin-bottom: 8pt; }
    .contact { font-size: 10pt; color: #555; margin-bottom: 4pt; }
    .languages { font-size: 10pt; color: #777; margin-bottom: 6pt; }
    .summary { font-size: 10.5pt; color: #444; margin-bottom: 16pt; font-style: italic; line-height: 1.5; }
    .job { margin-bottom: 12pt; page-break-inside: avoid; }
    .job-header { margin-bottom: 4pt; }
    .job-title { font-weight: bold; }
    .job-company { color: #555; }
    .job-meta { font-size: 10pt; color: #777; float: right; }
    .job-context { font-style: italic; color: #555; font-size: 10pt; margin-bottom: 4pt; }
    ul { margin: 4pt 0 8pt 18pt; padding: 0; }
    li { margin-bottom: 2pt; font-size: 10.5pt; }
    .tech-tags { font-size: 9pt; color: #555; margin-top: 4pt; }
    .skills-table { width: 100%; border-collapse: collapse; margin-bottom: 12pt; }
    .skills-table td { padding: 6pt 8pt; border: 1pt solid #ddd; vertical-align: top; width: 50%; }
    .skills-table h4 { font-size: 10pt; margin: 0 0 2pt 0; color: #1a1a1a; text-transform: uppercase; }
    .skills-table p { font-size: 10pt; margin: 0; color: #555; }
    .edu-table { width: 100%; }
    .edu-table td { padding: 4pt 0; vertical-align: top; }
    .edu-year { width: 80pt; font-weight: bold; font-family: Consolas, monospace; font-size: 10pt; }
    .section { margin-bottom: 16pt; }
    strong { color: #1a1a1a; }
</style>
</head>
